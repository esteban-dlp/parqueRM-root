{
  "appName": "ParqueRM",
  "version": "{{VERSION}}",
  "canonicalHost": "parque.rm.local",
  "localHostnames": ["parque.rm.local", "parquerm.local"],
  "serverIp": "{{SERVER_IP}}",
  "currentIpv4Addresses": ["{{SERVER_IP}}"],
  "recommendedUrl": "{{FRONTEND_URL}}",
  "frontendUrl": "{{FRONTEND_URL}}",
  "backendUrl": "{{BACKEND_URL}}",
  "swaggerUrl": "{{SWAGGER_URL}}",
  "fallbackUrls": ["http://parquerm.local", "http://localhost", "http://127.0.0.1", "http://{{SERVER_IP}}"],
  "hostsConfigured": true,
  "installDir": "{{INSTALL_DIR}}",
  "dbName": "{{DB_NAME}}",
  "dbUser": "{{DB_USER}}",
  "ports": {
    "frontend": {{FRONTEND_PORT}},
    "backend": {{BACKEND_PORT}},
    "sqlserver": 1433
  }
}
